# Production environment for Cloud Run
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file and fill in the real values.
# In production, values are injected via Secret Manager (--set-secrets flag).
# NEVER commit the actual .env file to git.

NODE_ENV=production
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
# Cloud SQL via unix socket (recommended for Cloud Run)
# Format: postgresql://USER:PASSWORD@/DATABASE?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql://taskflow:CHANGE_ME@/taskflow?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME

# Alternative: individual PG params (for non-Cloud SQL environments)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=taskflow
# PGUSER=taskflow
# PGPASSWORD=CHANGE_ME

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_BASE64_64
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your frontend URL (GCS bucket URL or custom domain)
CORS_ORIGIN=https://storage.googleapis.com/PROJECT_ID-taskflow-frontend
